name: ML Pipeline

on:
  push:
    branches: [ main ]

jobs:
  train:
    runs-on: ubuntu-latest

    steps:
    - name: Clonar repositorio
      uses: actions/checkout@v3

    - name: Instalar Python
      uses: actions/setup-python@v4
      with:
        python-version: 3.10

    - name: Instalar dependencias
      run: |
        pip install -r requirements.txt

    - name: Ejecutar entrenamiento
      run: |
        python src/train.py

    - name: Ejecutar tests
      run: |
        pytest
